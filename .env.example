# =============================================================================
# DoCourse — variabile de mediu necesare
# =============================================================================
# Copiază acest fișier în .env.local și completează valorile reale.
# .env.local este în .gitignore și NU se commitează niciodată.
# Valorile de producție se setează în Vercel Dashboard → Settings → Environment Variables.
# =============================================================================

# --- Supabase (publice — sigure în browser) ---
# Găsești în: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Găsești în: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Supabase (server-side only — nu expune în browser) ---
# Găsești în: Supabase Dashboard → Project Settings → API → service_role secret
# Format: eyJ... (JWT lung)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe (server-side only) ---
# Găsești în: Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Web Push Notifications (public — sigur în browser) ---
# Generezi cu: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
